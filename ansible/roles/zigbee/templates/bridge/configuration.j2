homeassistant: true
permit_join: false

frontend:
  port: 8080

mqtt:
  base_topic: "{{ zigbee_base_topic }}"
  server: "{{ zigbee_mqtt_server }}"
#  ca: "/app/data/secure/ca.crt"
  client_id: "{{ zigbee_client_id }}"
  user: "!secret mqtt_user"
  password: "!secret mqtt_password"
  reject_unauthorized: false
  include_device_information: true
  keepalive: 60
  version: 4

serial:
  port: "{{ zigbee_serial_port }}"
  disable_led: false

advanced:
  pan_id: {{ zigbee_pan_id }}
  channel: {{ zigbee_channel }}
  cache_state: true
  log_level: "debug"
  log_output:
    - "console"
  baudrate: 115200
  rtscts: true
  network_key: "!secret zigbee_network_key"
  last_seen: "ISO_8601"
  elapsed: true
  availability_timeout: 60
  availability_lag: 10
  report: true
  homeassistant_discovery_topic: "homeassistant"
  homeassistant_status_topic: "hass/status"

experimental:
  transmit_power: 20

